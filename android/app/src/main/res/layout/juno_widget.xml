<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- App name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌙 Juno"
            android:textColor="#FF2D78"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <TextView
            android:id="@+id/widget_last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Now"
            android:textColor="#8B5A73"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2D1A2A"
        android:layout_marginBottom="12dp" />

    <!-- Main content: cycle day + phase -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Day number (big) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/widget_day_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAY"
                android:textColor="#8B5A73"
                android:textSize="9sp"
                android:letterSpacing="0.12" />

            <TextView
                android:id="@+id/widget_day_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FF2D78"
                android:textSize="42sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-4dp" />
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="52dp"
            android:background="#2D1A2A"
            android:layout_marginEnd="16dp" />

        <!-- Phase + stats column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Phase badge -->
            <TextView
                android:id="@+id/widget_phase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FF2D78"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Period countdown -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🩸 "
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_period_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Period —"
                    android:textColor="#D4A0BB"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Cycle length -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 "
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_cycle_length"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— day cycle"
                    android:textColor="#D4A0BB"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Tap to open hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to open Juno"
        android:textColor="#5A3D50"
        android:textSize="9sp"
        android:gravity="end"
        android:layout_marginTop="10dp" />

</LinearLayout>
